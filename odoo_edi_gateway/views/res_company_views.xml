<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_edi" model="ir.ui.view">
        <field name="name">res.company.form.edi</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[last()]" position="after">
                <page string="EDI Gateway" name="edi_gateway">
                    <group string="PDP Configuration">
                        <field name="edi_pdp_provider"/>
                        <field name="edi_super_pdp_sandbox" invisible="edi_pdp_provider != 'super_pdp'"/>
                    </group>
                    <group string="SUPER PDP OAuth2 Credentials" invisible="edi_pdp_provider != 'super_pdp'">
                        <field name="edi_super_pdp_client_id"/>
                        <field name="edi_super_pdp_client_secret" password="True"/>
                        <field name="edi_super_pdp_auth_url"/>
                        <field name="edi_super_pdp_base_url"/>
                    </group>
                    <group string="SUPER PDP Token Cache (readonly)" invisible="edi_pdp_provider != 'super_pdp'">
                        <field name="edi_super_pdp_access_token" readonly="True"/>
                        <field name="edi_super_pdp_token_expiry" readonly="True"/>
                    </group>
                    <group string="Webhook Security">
                        <field name="edi_webhook_secret" password="True"/>
                    </group>
                    <group string="Fallback Polling">
                        <field name="edi_polling_enabled"/>
                        <field name="edi_polling_interval" invisible="not edi_polling_enabled"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
