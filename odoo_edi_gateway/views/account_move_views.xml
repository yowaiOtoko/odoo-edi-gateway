<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_edi" model="ir.ui.view">
        <field name="name">account.move.form.edi</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <!-- Status bar button -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_edi_logs"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-exchange"
                        invisible="edi_log_count == 0">
                    <field name="edi_log_count" widget="statinfo" string="EDI Logs"/>
                </button>
            </xpath>
            <!-- Send EDI button -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_send_edi"
                        string="Send EDI"
                        type="object"
                        class="btn-primary"
                        icon="fa-paper-plane"
                    invisible="state != 'posted'"/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_send_sandbox_test_edi"
                        string="Send Sandbox Test"
                        type="object"
                        class="btn-primary"
                        icon="fa-flask"
                    invisible="state != 'posted' or edi_company_provider != 'super_pdp' or not edi_company_sandbox"/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_poll_edi_status_now"
                        string="Poll EDI Now"
                        type="object"
                        class="btn-primary"
                        icon="fa-refresh"
                    invisible="not edi_external_id"/>
            </xpath>
            <!-- EDI status tab -->
            <xpath expr="//sheet/notebook" position="inside">
                <page string="EDI" name="edi_tab" invisible="not edi_state">
                    <group>
                        <group string="EDI Status">
                            <field name="edi_state" widget="badge"
                                   decoration-success="edi_state in ('accepted', 'delivered')"
                                   decoration-warning="edi_state in ('queued', 'sent')"
                                   decoration-danger="edi_state in ('rejected', 'error')"/>
                            <field name="edi_provider"/>
                            <field name="edi_external_id"/>
                            <field name="edi_sent_at"/>
                        </group>
                        <group string="Error">
                            <field name="edi_last_error" invisible="not edi_last_error"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
