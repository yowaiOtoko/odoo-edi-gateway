<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_edi_invoice_log_list" model="ir.ui.view">
        <field name="name">edi.invoice.log.list</field>
        <field name="model">edi.invoice.log</field>
        <field name="arch" type="xml">
            <list string="EDI Audit Logs" create="false" edit="false" delete="false">
                <field name="create_date" string="Timestamp"/>
                <field name="move_id"/>
                <field name="event_type"/>
                <field name="old_state"/>
                <field name="new_state"/>
            </list>
        </field>
    </record>

    <record id="view_edi_invoice_log_form" model="ir.ui.view">
        <field name="name">edi.invoice.log.form</field>
        <field name="model">edi.invoice.log</field>
        <field name="arch" type="xml">
            <form string="EDI Audit Log" create="false" edit="false">
                <sheet>
                    <group>
                        <group>
                            <field name="move_id"/>
                            <field name="event_type"/>
                            <field name="old_state"/>
                            <field name="new_state"/>
                            <field name="create_date" string="Timestamp"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Payload Sent">
                            <field name="payload" widget="text"/>
                        </page>
                        <page string="Provider Response">
                            <field name="provider_response" widget="text"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_edi_invoice_log" model="ir.actions.act_window">
        <field name="name">EDI Audit Logs</field>
        <field name="res_model">edi.invoice.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
